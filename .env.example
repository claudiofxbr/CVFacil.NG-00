# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Obtenha em: https://ai.google.dev
# Sem prefixo NEXT_PUBLIC_ de propósito: só é lida em rotas server-side (app/api/*),
# nunca deve ser referenciada em código de componente/cliente.
GEMINI_API_KEY=

# ── Neon PostgreSQL ────────────────────────────────────────────────────────────
# Obtenha em: https://console.neon.tech → seu projeto → Connection string
# DATABASE_URL: endpoint com pooler (usado pela aplicação em runtime)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
# DIRECT_URL: endpoint direto, sem pooler (usado só pelo Prisma Migrate)
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── JWT Auth ───────────────────────────────────────────────────────────────────
# Gere um secret seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=seu_jwt_secret_muito_secreto_aqui

# Cookie de sessao (auth-token) e sempre httpOnly + SameSite=Strict. O flag
# Secure so deve ser "true" quando o app estiver servido via HTTPS -- em HTTP
# puro o navegador recusa enviar cookies Secure de volta, quebrando o login.
# Producao ja serve via HTTPS (ver SECURITY.md) e usa "true". Em dev local
# (HTTP puro), mantenha "false".
COOKIE_SECURE=false

# ── Bootstrap do administrador ──────────────────────────────────────────────────
# Se definido, o próximo cadastro com este e-mail vira automaticamente 'Administrador'.
# Deixe vazio depois de criar o admin, ou remova a variável em produção.
ADMIN_SEED_EMAIL=

# ── Expurgo agendado de notificações ────────────────────────────────────────────
# Segredo usado pelo crontab da VPS para autorizar POST /api/admin/purge-notifications
# (roda a cada 60 dias — ver DEPLOY.md). Gere com:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Webhook secret — gerado ao criar o webhook em Stripe Dashboard → Webhooks
# Configure a URL: https://seudominio.com/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── URL do App ────────────────────────────────────────────────────────────────
# URL pública do app em produção (sem barra final)
NEXT_PUBLIC_APP_URL=https://cvfacil.ng
